{
  "name": "custom-md-blocks",
  "displayName": "custom-md-blocks",
  "description": "Creating custom formatting for blocks of code inside markdown files.",
  "version": "0.3.0",
  "publisher": "JakubKosidowski",
  "author": "Jakub Kosidowski",
  "icon": "assets/custom-md-blocks-icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git@github.com:Shertie/Custom-MD-Blocks.git"
  },
  "engines": {
    "vscode": "^1.107.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:markdown"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "markdown",
        "configuration": "./language-configuration.json"
      }
    ],
    "commands": [
      {
        "command": "customMdBlocks.showPreview",
        "title": "Custom MD Blocks: Show Preview",
        "icon": "$(open-preview)"
      },
      {
        "command": "customMdBlocks.importTemplate",
        "title": "Custom MD Blocks: Import Template"
      },
      {
        "command": "customMdBlocks.toggleBold",
        "title": "Custom MD Blocks: Toggle Bold"
      },
      {
        "command": "customMdBlocks.toggleItalic",
        "title": "Custom MD Blocks: Toggle Italic"
      },
      {
        "command": "customMdBlocks.generateTOC",
        "title": "Custom MD Blocks: Generate Table of Contents"
      }
    ],
    "keybindings": [
      {
        "command": "customMdBlocks.toggleBold",
        "key": "ctrl+b",
        "mac": "cmd+b",
        "when": "editorTextFocus && editorLangId == 'markdown'"
      },
      {
        "command": "customMdBlocks.toggleItalic",
        "key": "ctrl+i",
        "mac": "cmd+i",
        "when": "editorTextFocus && editorLangId == 'markdown'"
      }
    ],
    "configuration": {
      "title": "Custom MD Blocks",
      "properties": {
        "customMdBlocks.pdfExportMargin": {
          "type": "number",
          "default": 10,
          "description": "Margin for PDF export in mm."
        },
        "customMdBlocks.geminiApiKey": {
          "type": "string",
          "default": "",
          "description": "API Key for Google Gemini (used for AI blocks)."
        },
        "customMdBlocks.rules": {
          "type": "object",
          "default": {
            "tree": {
              "symbols": {
                "├──": "#e06c75",
                "└──": "#98c379",
                "│": "#56b6c2"
              }
            }
          },
          "description": "Global configuration for custom code blocks in Markdown."
        }
      }
    },
    "menus": {
      "editor/title": [
        {
          "command": "customMdBlocks.showPreview",
          "group": "navigation",
          "when": "resourceLangId == markdown"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.107.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "@iktakahiro/markdown-it-katex": "^4.0.1",
    "markdown-it": "^14.2.0",
    "markdown-it-task-lists": "^2.1.1",
    "node-fetch": "^2.7.0"
  }
}
